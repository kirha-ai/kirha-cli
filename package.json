{
  "name": "@kirha/cli",
  "version": "0.1.1",
  "description": "Official command-line interface for the Kirha API. LLM-friendly, JSON-first.",
  "type": "module",
  "bin": {
    "kirha": "./dist/kirha.js"
  },
  "files": [
    "dist/kirha.js",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build ./src/main.ts --outfile dist/kirha.js --target node --minify",
    "build:binary": "bun build ./src/main.ts --compile --outfile dist/binaries/kirha",
    "build:binaries": "bun run build:binary:darwin-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:linux-x64 && bun run build:binary:linux-arm64",
    "build:binary:darwin-arm64": "bun build ./src/main.ts --compile --target=bun-darwin-arm64 --outfile dist/binaries/kirha-darwin-arm64",
    "build:binary:darwin-x64": "bun build ./src/main.ts --compile --target=bun-darwin-x64 --outfile dist/binaries/kirha-darwin-x64",
    "build:binary:linux-x64": "bun build ./src/main.ts --compile --target=bun-linux-x64 --outfile dist/binaries/kirha-linux-x64",
    "build:binary:linux-arm64": "bun build ./src/main.ts --compile --target=bun-linux-arm64 --outfile dist/binaries/kirha-linux-arm64",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write",
    "prepare": "simple-git-hooks || true",
    "prepublishOnly": "bun run build"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,json}": "biome check --write --no-errors-on-unmatched"
  },
  "keywords": [
    "kirha",
    "cli",
    "search",
    "ai",
    "llm",
    "agent"
  ],
  "author": "Kirha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kirha-ai/kirha-cli"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/bun": "^1.3.12",
    "commander": "^12.1.0",
    "kirha": "^0.1.3",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.0.0"
  }
}
